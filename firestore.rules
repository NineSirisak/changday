rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Profile helper
    function isValidProfile(data) {
      return data.id is string && data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    // Customer helper
    function isValidCustomer(data) {
      return data.id is string && data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    // Quotation helper
    function isValidQuotation(data) {
      return data.id is string && data.docNo is string && data.docNo.size() > 0 && data.docNo.size() <= 100;
    }

    // Match rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /profiles/{profileId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(profileId) && isValidProfile(incoming());
        allow delete: if isOwner(userId);
      }

      match /customers/{customerId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(customerId) && isValidCustomer(incoming());
        allow delete: if isOwner(userId);
      }

      match /quotations/{quotationId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(quotationId) && isValidQuotation(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
